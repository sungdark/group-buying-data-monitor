# 飞书机器人配置
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 数据存储配置
DATA_DIR=./data/
LOG_DIR=./logs/

# 抓取配置
MAX_RETRY_COUNT=3
REQUEST_TIMEOUT=30000
RATE_LIMIT_DELAY=2000

# 评价平台配置
DIANPING_CITY=上海
DOUYIN_CITY=上海
AMAP_CITY=上海

# 外卖平台配置
MEITUAN_AREA=浦东新区
ELEME_AREA=浦东新区
JD_AREA=浦东新区

# 代理配置（可选）
HTTP_PROXY=
HTTPS_PROXY=

# 日志级别
LOG_LEVEL=info
